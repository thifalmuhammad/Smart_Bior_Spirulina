rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /datapoints/{dataPointId} {
      allow read: if true;
      allow create, update: if request.auth != null && isValidDataPoint(request.resource.data);
      allow delete: if request.auth != null;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidDataPoint(data) {
      return data.keys().hasAll(['timestamp', 'temperature', 'opticalDensity']) 
        && data.timestamp is number
        && data.temperature is number
        && data.opticalDensity is number;
    }
  }
}
